{
  "name": "interview-coordination-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "docker:build": "docker build -t interview-app .",
    "docker:compose:up": "docker compose up --build --remove-orphans",
    "docker:compose:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:seed": "docker compose exec -T app npm run db:push && docker compose exec -T app npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.0",
    "next": "^14.0.0",
    "nodemailer": "^6.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^6.4.8",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
