{
  "name": "interview-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "sh -c 'npx prisma generate --schema=$(test -f ./prisma/schema.prisma && echo ./prisma/schema.prisma || echo ../prisma/schema.prisma)'",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/server.js",
    "dev": "npm run prisma:generate && npx ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
